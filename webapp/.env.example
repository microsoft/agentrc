# GitHub token for scanning private repos (optional)
GH_TOKEN_FOR_SCAN=

# Enable report sharing
ENABLE_SHARING=true

# Report storage directory (use :memory: for in-memory storage in dev/tests)
REPORTS_DIR=:memory:

# Custom domain hostname for OG/Twitter meta tags (real DNS hostname with at least one dot, no protocol)
# Must match the domain configured in GitHub vars.CUSTOM_DOMAIN (e.g. app.example.com)
CUSTOM_DOMAIN=

# Environment
NODE_ENV=development
